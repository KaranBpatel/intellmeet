{
    "version": 2,
    "builds": [
        {
            "src": "api/index.php",
            "use": "@vercel/php@0.7.2"
        },
        {
            "src": "public/**",
            "use": "@vercel/static"
        }
    ],
    "routes": [
        {
            "src": "/(.*)",
            "dest": "/api/index.php"
        }
    ],
    "installCommand": "curl -sS https://getcomposer.org/installer | php && php composer.phar install && npm install",
    "buildCommand": "php artisan config:cache && php artisan route:cache",
    "outputDirectory": "public",
    "env": {
        "APP_ENV": "production",
        "APP_DEBUG": "false",
        "LOG_CHANNEL": "stderr",
        "CACHE_DRIVER": "array",
        "SESSION_DRIVER": "array"
    }
}
